{
  "name": "accept-to-ship-action",
  "version": "0.8.6",
  "description": "This GitHub Action automatically merges approved pull requests when they include an #accept2ship trigger.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CatChen/accept-to-ship-action.git"
  },
  "author": "Cat Chen",
  "homepage": "https://github.com/CatChen/accept-to-ship-action#readme",
  "bugs": {
    "url": "https://github.com/CatChen/accept-to-ship-action/issues"
  },
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "rm -rf dist && tsc",
    "bundle": "rm -rf bundle && ncc build src/index.ts --source-map --license licenses.txt --out bundle",
    "codegen": "rm -rf src/__graphql__ && graphql-codegen-esm --config codegen.ts",
    "format": "prettier --write .",
    "lint": "eslint -c eslint.config.js",
    "postpublish": "pinst --enable",
    "prepare": "is-ci || husky",
    "prepublishOnly": "pinst --disable && yarn build",
    "preversion": "yarn && yarn build && yarn bundle",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@actions/github": "^9.0.0",
    "@graphql-typed-document-node/core": "^3.2.0",
    "@octokit/core": "^7.0.0",
    "@octokit/graphql": "^9.0.3",
    "@octokit/plugin-retry": "^8.0.1",
    "@octokit/plugin-throttling": "^11.0.1",
    "@octokit/webhooks-types": "^7.6.1"
  },
  "devDependencies": {
    "@0no-co/graphqlsp": "^1.12.12",
    "@eslint/eslintrc": "^3.3.3",
    "@eslint/js": "^10.0.1",
    "@graphql-codegen/cli": "6.3.1",
    "@graphql-codegen/typescript": "5.0.10",
    "@graphql-codegen/typescript-document-nodes": "5.0.10",
    "@graphql-eslint/eslint-plugin": "^4.4.0",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@types/node": "^25.3.5",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vercel/ncc": "^0.38.1",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.0.0",
    "graphql": "^16.13.1",
    "husky": "^9.0.11",
    "is-ci": "^4.1.0",
    "lint-staged": "^16.3.2",
    "pinst": "^3.0.0",
    "prettier": "^3.3.2",
    "prettier-plugin-package": "^2.0.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.0.0"
  },
  "types": "dist/index.d.js",
  "funding": "https://github.com/CatChen/accept-to-ship-action?sponsor=1",
  "lint-staged": {
    "*.{ts,js}": [
      "yarn format",
      "yarn lint --fix"
    ],
    "*.{json,yml,yaml,md,markdown,svg}": "yarn format"
  },
  "packageManager": "yarn@4.13.0"
}
